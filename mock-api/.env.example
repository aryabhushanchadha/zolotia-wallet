PORT=4000

# Telegram bot (now runs inside this same service)
BOT_TOKEN=your_bot_token_here
# Public HTTPS URL of this service (a tunnel URL in local dev, or left unset in
# production so it falls back to Render's own RENDER_EXTERNAL_URL)
MINI_APP_URL=https://your-tunnel-or-deployed-url

# Daily marketing broadcast
BROADCAST_HOUR_UTC=9

# Persistent DB (Turso/libSQL). Leave both unset for local dev — falls back to
# an embedded file DB at mock-api/data/zolotia.db, no account needed.
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=
